# ═══════════════════════════════════════════════════════
# Ventura Platform — Environment Configuration
# cp .env.example .env  then fill in your values
# ═══════════════════════════════════════════════════════

PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001

# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

DB_PATH=./ventura.db

# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_TOKENS=8192
AGENT_CRON_SCHEDULE=0 2 * * *

STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PLATFORM_FEE_PERCENT=20
STRIPE_PRICE_BUILDER_MONTHLY=price_xxxx
STRIPE_PRICE_FLEET_MONTHLY=price_xxxx

SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_api_key
SMTP_FROM=noreply@ventura.ai

PLATFORM_DOMAIN=ventura.ai

VERCEL_TOKEN=
VERCEL_TEAM_ID=

BRAVE_SEARCH_API_KEY=

TWITTER_BEARER_TOKEN=
LINKEDIN_ACCESS_TOKEN=

WS_HEARTBEAT_INTERVAL=30000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
